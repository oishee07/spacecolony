<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark"
    android:padding="8dp">

    <TextView
        android:text="MISSION CONTROL"
        android:textColor="#FFD700"
        android:textSize="18sp"
        android:textStyle="bold"
        android:padding="8dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <TextView
        android:id="@+id/tv_mission_count"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#AAAAAA"
        android:textSize="12sp"
        android:padding="4dp"/>

    <RadioGroup
        android:id="@+id/rg_squad_size"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="4dp">

        <RadioButton
            android:id="@+id/rb_squad2"
            android:text="Squad of 2"
            android:textColor="@color/white"
            android:checked="true"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"/>

        <RadioButton
            android:id="@+id/rb_squad3"
            android:text="Squad of 3"
            android:textColor="@color/white"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

    </RadioGroup>

    <TextView
        android:id="@+id/tv_empty_mc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No crew in Mission Control. Move crew here first."
        android:textColor="#888888"
        android:gravity="center"
        android:padding="32dp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_mission_crew"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btn_mc_to_quarters"
            android:text="← Quarters"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:backgroundTint="@color/pilot_color"
            android:textColor="@color/white"
            android:layout_marginEnd="4dp"/>

        <Button
            android:id="@+id/btn_launch_mission"
            android:text="🚀 Launch!"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:backgroundTint="@color/soldier_color"
            android:textColor="@color/white"/>

    </LinearLayout>
</LinearLayout>