<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/bg_dark" android:padding="16dp">

    <TextView android:text="🏥 MEDBAY" android:textColor="#FFD700"
        android:textSize="20sp" android:textStyle="bold"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"/>

    <ListView android:id="@+id/list_medbay_crew"
        android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:textColor="@color/white"/>

    <TextView android:id="@+id/tv_medbay_result"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:textColor="#AAFFAA" android:padding="8dp"/>

    <Button android:id="@+id/btn_discharge_medbay"
        android:text="💊 Discharge to Quarters"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:backgroundTint="@color/medic_color" android:textColor="@color/white"/>
</LinearLayout>