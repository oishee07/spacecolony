<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark"
    android:padding="8dp">

    <TextView
        android:text="🏥 MEDBAY"
        android:textColor="#FFD700"
        android:textSize="18sp"
        android:textStyle="bold"
        android:padding="8dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <TextView
        android:text="Crew members here were defeated in battle. Discharge them back to Quarters."
        android:textColor="#AAAAAA"
        android:textSize="12sp"
        android:padding="8dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <TextView
        android:id="@+id/tv_empty_medbay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No crew in Medbay. Everyone is healthy!"
        android:textColor="#888888"
        android:gravity="center"
        android:padding="32dp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_medbay_crew"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <Button
        android:id="@+id/btn_discharge"
        android:text="💊 Discharge Selected to Quarters"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:backgroundTint="@color/medic_color"
        android:textColor="@color/white"/>

</LinearLayout>